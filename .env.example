# ==============================================================
# .env.example  —  TEMPLATE (safe to commit)
#
# HOW TO USE:
#   1. Copy this file to a real one:   cp .env.example .env
#   2. The real .env is in .gitignore and is NEVER committed.
#   3. Fill in values in .env only if/when you actually need them.
#
# This project needs NO secrets to run its core pipeline — the
# data source is public. These keys exist only for optional
# upgrades (e.g. a paid live-odds API later). Keeping them here,
# empty, documents intent without exposing anything.
# ==============================================================

# Optional: a live football data/odds API key, IF you add one later.
LIVE_DATA_API_KEY=

# Optional: override the default log level (DEBUG, INFO, WARNING).
LOG_LEVEL=INFO

# Optional: hard cap on download size in MB (DoS guard).
MAX_FILE_SIZE_MB=50
